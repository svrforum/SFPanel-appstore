{
  "id": "postgres",
  "name": "PostgreSQL",
  "description": {
    "ko": "세계에서 가장 진보된 오픈소스 관계형 데이터베이스. ACID 호환, 확장 가능.",
    "en": "The world's most advanced open source relational database. ACID compliant and extensible."
  },
  "category": "database",
  "version": "17",
  "website": "https://www.postgresql.org",
  "source": "https://github.com/postgres/postgres",
  "icon": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/svg/postgres.svg",
  "ports": [5432],
  "features": {
    "ko": ["ACID 트랜잭션", "JSON/JSONB 지원", "전문 검색", "확장 시스템 (PostGIS 등)"],
    "en": ["ACID transactions", "JSON/JSONB support", "Full-text search", "Extension system (PostGIS, etc.)"]
  },
  "env": [
    { "key": "POSTGRES_USER", "description": { "ko": "관리자 사용자명", "en": "Admin username" }, "default": "postgres", "required": true },
    { "key": "POSTGRES_PASSWORD", "description": { "ko": "관리자 비밀번호", "en": "Admin password" }, "default": "changeme", "required": true },
    { "key": "POSTGRES_DB", "description": { "ko": "기본 데이터베이스명", "en": "Default database name" }, "default": "postgres", "required": false }
  ]
}
