{
  "id": "grafana",
  "name": "Grafana",
  "description": { "ko": "오픈소스 데이터 시각화 및 모니터링", "en": "Open source data visualization and monitoring" },
  "category": "monitoring",
  "version": "1.0.0",
  "website": "https://grafana.com",
  "source": "https://github.com/grafana/grafana",
  "icon": "https://raw.githubusercontent.com/grafana/grafana/main/public/img/grafana_icon.svg",
  "ports": [3000],
  "features": [
    { "title": { "ko": "대시보드", "en": "Dashboards" }, "description": { "ko": "드래그 앤 드롭 패널로 대시보드 구성", "en": "Build dashboards with drag and drop panels" }, "icon": "📊" },
    { "title": { "ko": "데이터소스", "en": "Datasources" }, "description": { "ko": "Prometheus, InfluxDB, MySQL 등 지원", "en": "Support Prometheus, InfluxDB, MySQL and more" }, "icon": "🔌" },
    { "title": { "ko": "알림", "en": "Alerting" }, "description": { "ko": "조건 기반 알림 규칙 설정", "en": "Set up condition-based alert rules" }, "icon": "🔔" },
    { "title": { "ko": "플러그인", "en": "Plugins" }, "description": { "ko": "수백 개의 커뮤니티 플러그인", "en": "Hundreds of community plugins" }, "icon": "🧩" }
  ],
  "env": [
    { "key": "PORT", "label": { "ko": "외부 포트", "en": "External Port" }, "type": "port", "default": "3000" },
    { "key": "GF_SECURITY_ADMIN_PASSWORD", "label": { "ko": "관리자 비밀번호", "en": "Admin Password" }, "type": "password", "required": true, "generate": true }
  ]
}
