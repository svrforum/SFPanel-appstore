{
  "id": "nginx-proxy-manager",
  "name": "Nginx Proxy Manager",
  "description": {
    "ko": "SSL 관리 기능이 포함된 리버스 프록시",
    "en": "Reverse proxy with SSL management"
  },
  "category": "dev",
  "version": "1.0.0",
  "website": "https://nginxproxymanager.com",
  "source": "https://github.com/NginxProxyManager/nginx-proxy-manager",
  "ports": [80, 81, 443],
  "env": [
    {
      "key": "HTTP_PORT",
      "label": { "ko": "HTTP 포트", "en": "HTTP Port" },
      "type": "port",
      "default": "80"
    },
    {
      "key": "ADMIN_PORT",
      "label": { "ko": "관리자 포트", "en": "Admin Port" },
      "type": "port",
      "default": "81"
    },
    {
      "key": "HTTPS_PORT",
      "label": { "ko": "HTTPS 포트", "en": "HTTPS Port" },
      "type": "port",
      "default": "443"
    },
    {
      "key": "DB_PASSWORD",
      "label": { "ko": "DB 비밀번호", "en": "DB Password" },
      "type": "password",
      "required": true,
      "generate": true
    }
  ]
}
