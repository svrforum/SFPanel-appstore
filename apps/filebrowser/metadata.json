{
  "id": "filebrowser",
  "name": "File Browser",
  "description": { "ko": "웹 기반 파일 관리자", "en": "Web-based file manager" },
  "category": "cloud",
  "version": "1.0.0",
  "website": "https://filebrowser.org",
  "source": "https://github.com/filebrowser/filebrowser",
